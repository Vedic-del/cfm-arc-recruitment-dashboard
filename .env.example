# Supabase project URL (not secret). Either name works.
NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_URL=

# Server-only service-role key — the app's trusted gateway to the database.
# Get it from Supabase → Project Settings → API → service_role. NEVER prefix
# with NEXT_PUBLIC and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy anon key — only used as a fallback until the service-role key is set.
# Safe to remove once SUPABASE_SERVICE_ROLE_KEY is configured and RLS is on.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI (resume parsing + JD matching). Server-only.
GROQ_API_KEY=

# Shared team password that gates the whole app. Leave blank to keep the app
# open (no login). Set any value to require it before anyone can view data.
# Public /scorecard/* links stay accessible without it.
APP_PASSWORD=
